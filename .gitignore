# Build outputs
Build/
dist/
*.o
*.obj
*.efi.unsigned
tools/abl-patcher/abl-patcher
tools/abl-patcher/abl-patcher-android
tools/fv-unwrap/fv-unwrap
tools/fv-unwrap/fv-unwrap-android
tools/gbl-pack/gbl-pack
tools/gbl-pack/gbl-pack-android
tools/gbl-commit/gbl-commit
tools/gbl-commit/gbl-commit-android
tools/vbmeta-graft/vbmeta-graft
tools/vbmeta-graft/vbmeta-graft-android
tools/mode2-profile/mode2-profile
tools/mode2-profile/mode2-profile-android
tools/gblp1-inspect/gblp1-inspect
tools/gblp1-inspect/gblp1-inspect-android
tests/*/test_*
!tests/*/test_*.c
!tests/*/test_*.h
!tests/*/test_*.sh

# Host test helper binaries — sources tracked, compiled binaries not
tests/host/helpers/*
!tests/host/helpers/*.c
!tests/host/helpers/*.h
!tests/host/helpers/*.sh
!tests/host/helpers/Makefile
tests/host/.last/

# Session/tooling state
.claude/
.omc/
tests/*/.omc/

# Stock OTA partition images — top-level only.
# (Anchored with a leading slash so `tests/images/` stays tracked: that's
# where committed ABL fixtures for the patch test harness live.)
/images/
!/images/.gitkeep
!/images/README.md

# Mode-2 profile payloads — gitignored; manifest.json is tracked (Plan 2)
profiles/*/profile.h
profiles/*/[!manifest]*.bin

# Device test logs
logs/

# RE staging (transient)
.re-notes-staging/

# Python
__pycache__/
*.pyc
.venv/

# Editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
